// Prisma schema for PRIM AI Institute - defines all DB models and enums

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Profile {
  SCHOOL_STUDENT
  COLLEGE_STUDENT
  WORKING_PROFESSIONAL
  BUSINESS_OWNER
  OTHER
}

enum Course {
  LEVEL_1_FOUNDATION
  LEVEL_2A_GENERALIST
  LEVEL_2B_DEVELOPER
  NOT_SURE
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

model DemoBooking {
  id             String     @id @default(cuid())
  name           String
  phone          String
  profile        Profile
  courseInterest Course
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("demo_bookings")
}

model Enquiry {
  id             String     @id @default(cuid())
  name           String
  phone          String
  email          String?
  profile        Profile
  courseInterest Course
  message        String
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("enquiries")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admins")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── Blog Module ─────────────────────────────────────────────────────────────

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  color     String     @default("#00D4FF")
  posts     BlogPost[]
  createdAt DateTime   @default(now())

  @@map("blog_categories")
}

model BlogTag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  posts     BlogPostTag[]
  createdAt DateTime      @default(now())

  @@map("blog_tags")
}

model BlogAuthor {
  id          String     @id @default(cuid())
  name        String
  designation String?
  bio         String?
  avatarUrl   String?
  posts       BlogPost[]
  createdAt   DateTime   @default(now())

  @@map("blog_authors")
}

model BlogPost {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String
  content       String        @db.Text
  coverImageUrl String?
  status        BlogStatus    @default(DRAFT)
  readTimeMin   Int           @default(0)
  category      BlogCategory  @relation(fields: [categoryId], references: [id])
  categoryId    String
  author        BlogAuthor    @relation(fields: [authorId], references: [id])
  authorId      String
  tags          BlogPostTag[]
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("blog_posts")
}

model BlogPostTag {
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
  @@map("blog_post_tags")
}
