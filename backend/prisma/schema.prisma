// Prisma schema for PRIM AI Institute - defines all DB models and enums

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Profile {
  SCHOOL_STUDENT
  COLLEGE_STUDENT
  WORKING_PROFESSIONAL
  BUSINESS_OWNER
  OTHER
}

enum Course {
  LEVEL_1_FOUNDATION
  LEVEL_2A_GENERALIST
  LEVEL_2B_DEVELOPER
  NOT_SURE
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

model DemoBooking {
  id             String     @id @default(cuid())
  name           String
  phone          String
  profile        Profile
  courseInterest Course
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("demo_bookings")
}

model Enquiry {
  id             String     @id @default(cuid())
  name           String
  phone          String
  email          String?
  profile        Profile
  courseInterest Course
  message        String
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("enquiries")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admins")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Generic CMS store: one JSONB document per page/section (homePage, programPages, …).
// Replaces localStorage-only persistence so admin edits reach every visitor.
model PageContent {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt

  @@map("page_content")
}

// ─── Blog Module ─────────────────────────────────────────────────────────────

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  color     String     @default("#00D4FF")
  posts     BlogPost[]
  createdAt DateTime   @default(now())

  @@map("blog_categories")
}

model BlogTag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  posts     BlogPostTag[]
  createdAt DateTime      @default(now())

  @@map("blog_tags")
}

model BlogAuthor {
  id          String     @id @default(cuid())
  name        String
  designation String?
  bio         String?
  avatarUrl   String?
  posts       BlogPost[]
  createdAt   DateTime   @default(now())

  @@map("blog_authors")
}

model BlogPost {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String
  content       String        @db.Text
  coverImageUrl String?
  status        BlogStatus    @default(DRAFT)
  showAuthor    Boolean       @default(true)
  readTimeMin   Int           @default(0)
  category      BlogCategory  @relation(fields: [categoryId], references: [id])
  categoryId    String
  author        BlogAuthor    @relation(fields: [authorId], references: [id])
  authorId      String
  tags          BlogPostTag[]
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("blog_posts")
}

model BlogPostTag {
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

// ─── Courses Module ────────────────────────────────────────────────────────────

enum CourseLevel {
  L1_FOUNDATION
  L2A_GENERALIST
  L2B_DEVELOPER
}

model AiCourse {
  id               String                  @id @default(cuid())
  level            CourseLevel             @unique
  badgeText        String
  title            String
  tagline          String
  heroImageUrl     String?
  duration         String
  mentorship       String
  trainingDays     String
  language         String
  mode             String
  certificate      String
  placementInfo    String
  levelLabel       String
  ctaDemoText      String                  @default("Book Free Demo ➞")
  ctaWaText        String                  @default("💬 Chat on WhatsApp")
  ctaDownloadText  String                  @default("Download Syllabus")
  displayOrder     Int                     @default(0)
  whoItems         CourseWhoItem[]
  modules          CourseModule[]
  tools            CourseTool[]
  outcomes         CourseOutcome[]
  beforeAfter      CourseBeforeAfter?
  eligibilityItems CourseEligibilityItem[]
  faqs             CourseFAQ[]
  testimonials     CourseTestimonial[]
  updatedAt        DateTime                @updatedAt
  createdAt        DateTime                @default(now())

  @@map("courses")
}

model CourseWhoItem {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  emoji    String
  title    String
  desc     String
  order    Int      @default(0)

  @@map("course_who_items")
}

model CourseModule {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  label    String
  title    String
  topics   String[]
  order    Int      @default(0)

  @@map("course_modules")
}

model CourseTool {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  emoji    String
  name     String
  category String
  order    Int      @default(0)

  @@map("course_tools")
}

model CourseOutcome {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  desc     String
  order    Int      @default(0)

  @@map("course_outcomes")
}

model CourseBeforeAfter {
  id          String   @id @default(cuid())
  courseId    String   @unique
  course      AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  beforeItems String[]
  afterItems  String[]

  @@map("course_before_after")
}

model CourseEligibilityItem {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  text     String
  order    Int      @default(0)

  @@map("course_eligibility_items")
}

model CourseFAQ {
  id       String   @id @default(cuid())
  courseId String
  course   AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  question String
  answer   String
  order    Int      @default(0)

  @@map("course_faqs")
}

model CourseTestimonial {
  id         String   @id @default(cuid())
  courseId   String
  course     AiCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  initials   String
  name       String
  meta       String
  avatarGrad String
  quote      String
  before     String
  after      String
  order      Int      @default(0)

  @@map("course_testimonials")
}

// Singleton record for the /courses listing page content
model CoursesListingPage {
  id                String                  @id @default(cuid())
  heroTag           String
  heroHeadingMain   String
  heroHeadingAccent String
  heroSubtitle      String
  whoTag            String
  whoHeadingMain    String
  whoHeadingAccent  String
  ctaTag            String
  ctaHeading        String
  ctaDesc           String
  ctaBtnPrimary     String
  ctaBtnSecondary   String
  whoCards          CoursesListingWhoCard[]
  updatedAt         DateTime                @updatedAt

  @@map("courses_listing_page")
}

model CoursesListingWhoCard {
  id     String             @id @default(cuid())
  pageId String
  page   CoursesListingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  emoji  String
  title  String
  desc   String
  order  Int                @default(0)

  @@map("courses_listing_who_cards")
}

// ─── Tutorial Lead Capture ────────────────────────────────────────────────────

model TutorialLead {
  id                   String   @id @default(cuid())
  fullName             String
  mobile               String   @unique
  city                 String
  userType             String
  tutorialAccessed     String
  sourcePage           String
  tutorialsViewedCount Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("tutorial_leads")
}

// ─── Program Enrollments (standalone /program/:slug landing pages) ─────────────
// Separate from TutorialLead/DemoBooking/Enquiry by design - own admin section.

enum EnrollmentStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
}

model ProgramEnrollment {
  id             String           @id @default(cuid())
  fullName       String
  whatsappNumber String
  // Optional fields - a program's admin-configured form may or may not ask
  // for these (see PgFormFieldsConfig on the frontend); null when not asked.
  city           String?
  email          String?
  userType       String?
  // Which program page this came from. programTitle is a snapshot (not a
  // join) so the admin table stays readable even if a page is renamed/deleted.
  programSlug    String
  programTitle   String
  // Text snapshot of the batch they picked at submission time - protects
  // enrollment history from later edits/deletion of the batch in the CMS.
  batchName      String
  status         EnrollmentStatus @default(NEW)
  notes          String?
  // Repeat interest within the dedup window (see service) increments this
  // instead of creating a duplicate row.
  submissionCount Int             @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([whatsappNumber, programSlug])
  @@index([programSlug])
  @@index([status])
  @@map("program_enrollments")
}
