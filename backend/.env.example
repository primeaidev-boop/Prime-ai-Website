# ─── Database ────────────────────────────────────────────────────────────────
# NeonDB provides this string directly - copy it as-is (includes ?sslmode=require)
# Local dev: postgresql://USER:PASSWORD@localhost:5432/primai_db (no SSL needed)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/primai_db?sslmode=require"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="change-this-to-a-64-character-random-string"
JWT_EXPIRES_IN="8h"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://your-vercel-app.vercel.app"

# ─── Notifications ────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="PRIMAI"
ADMIN_WHATSAPP="91XXXXXXXXXX"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL="your@email.com"

# ─── DigitalOcean Spaces (media uploads) ──────────────────────────────────────
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_ENDPOINT="https://sgp1.digitaloceanspaces.com"
DO_SPACES_BUCKET=""
DO_SPACES_CDN_URL="https://your-bucket.sgp1.cdn.digitaloceanspaces.com"
